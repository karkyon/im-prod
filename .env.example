# ── アプリケーション ─────────────────────────────
NODE_ENV=development
APP_PORT_WEB=3040
APP_PORT_API=3041

# ── 既存DB接続（SQL Server / 現行imotodb） ────────
LEGACY_DB_HOST=
LEGACY_DB_PORT=1433
LEGACY_DB_NAME=imotodb
LEGACY_DB_USER=
LEGACY_DB_PASSWORD=

# ── 将来用PostgreSQL（Docker） ────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5441
POSTGRES_DB=im_prod
POSTGRES_USER=im_prod_user
POSTGRES_PASSWORD=

# ── 将来用Redis（Docker） ─────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6391

# ── 添付ファイルサーバー ──────────────────────────
FILE_SERVER_BASE_PATH=
FILE_SERVER_MOUNT_PATH=
